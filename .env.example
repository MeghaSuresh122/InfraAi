# # Non-codegen agents: OpenAI-compatible (Ollama, vLLM, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# MODEL_REQUIREMENT=qwen2.5:14b
# MODEL_CONFIG_PLAN=qwen2.5:14b
# MODEL_BUILDER=qwen2.5:14b
# MODEL_VALIDATOR_SOFT=qwen2.5:14b

# LLM Providers for different nodes
# Supported providers: openrouter, ollama, groq
# By default, all nodes use openrouter
LLM_PROVIDER_REQUIREMENT=openrouter
LLM_PROVIDER_CONFIG_PLAN=openrouter
LLM_PROVIDER_BUILDER=openrouter
LLM_PROVIDER_VALIDATOR_SOFT=openrouter
LLM_PROVIDER_CODEGEN=openrouter

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
MODEL_REQUIREMENT=qwen/qwen3-32b
MODEL_CONFIG_PLAN=qwen/qwen3-32b
MODEL_BUILDER=qwen/qwen3-32b
MODEL_VALIDATOR_SOFT=qwen/qwen3-32b
MODEL_CODEGEN=minimax/minimax-m2.5:free

# Groq provider configuration
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_API_KEY=your_groq_api_key

OPENAI_BASE_URL=
OPENAI_API_KEY=

# Git (clone/push target; branch created per artifact)
GIT_REPO_URL=https://github.com/MeghaSuresh122/InfraAi-test-terraform.git
GIT_DEFAULT_BRANCH=main
GIT_REMOTE_NAME=origin
GIT_AUTHOR_NAME=InfraAi
GIT_AUTHOR_EMAIL=infra-ai@local

# GitHub App for API push
GITHUB_APP_CLIENT_ID=your-client-id
GITHUB_APP_PEM_PATH=/path/to/private-key.pem
GITHUB_APP_INSTALLATION_ID=your-installation-id

# Optional
# MILVUS_URI=http://localhost:19530
# SKILL_RETRIEVAL_MODE=filesystem
