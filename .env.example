# # Non-codegen agents: OpenAI-compatible (Ollama, vLLM, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# MODEL_REQUIREMENT=qwen2.5:14b
# MODEL_CONFIG_PLAN=qwen2.5:14b
# MODEL_BUILDER=qwen2.5:14b
# MODEL_VALIDATOR_SOFT=qwen2.5:14b

# All agents use OpenRouter for both non-codegen and codegen
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
MODEL_REQUIREMENT=qwen/qwen3-32b
MODEL_CONFIG_PLAN=qwen/qwen3-32b
MODEL_BUILDER=qwen/qwen3-32b
MODEL_VALIDATOR_SOFT=qwen/qwen3-32b
MODEL_CODEGEN=minimax/minimax-m2.5:free

# Git (clone/push target; branch created per artifact)
GIT_REPO_URL=https://github.com/MeghaSuresh122/InfraAi-test-terraform.git
GIT_DEFAULT_BRANCH=main
GIT_REMOTE_NAME=origin
GIT_AUTHOR_NAME=InfraAi
GIT_AUTHOR_EMAIL=infra-ai@local

# Optional
# MILVUS_URI=http://localhost:19530
# SKILL_RETRIEVAL_MODE=filesystem
